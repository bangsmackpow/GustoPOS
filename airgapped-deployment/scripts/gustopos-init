#!/bin/bash
# gustopos-init - First-time setup for GustoPOS Debian appliance

set -e

echo "=========================================="
echo "GustoPOS Appliance - First-Time Setup"
echo "=========================================="
echo ""

# Generate SSL certificates if they don't exist
if [ ! -f /etc/gustopos/ssl/cert.pem ]; then
    echo "[1/4] Generating self-signed SSL certificates..."
    sudo mkdir -p /etc/gustopos/ssl
    sudo openssl req -x509 -newkey rsa:4096 \
        -keyout /etc/gustopos/ssl/key.pem \
        -out /etc/gustopos/ssl/cert.pem \
        -days 365 -nodes \
        -subj "/C=US/ST=State/L=City/O=GustoPOS/CN=gustopos.local" \
        2>/dev/null
    sudo chown -R gustopos:gustopos /etc/gustopos/ssl/
    echo "✓ SSL certificates generated"
else
    echo "[1/4] SSL certificates already exist (skipping)"
fi

# Create .env file from template if it doesn't exist
if [ ! -f /etc/gustopos/.env ]; then
    echo "[2/4] Creating .env configuration file..."
    sudo cp /etc/gustopos/.env.template /etc/gustopos/.env
    sudo chown gustopos:gustopos /etc/gustopos/.env
    echo "✓ .env file created"
else
    echo "[2/4] .env file already exists (skipping)"
fi

# Ensure Docker is running
echo "[3/4] Checking Docker service..."
if ! systemctl is-active --quiet docker; then
    sudo systemctl start docker
fi
echo "✓ Docker service ready"

# Ensure images are ready (pre-pulled during build)
echo "[4/4] Ensuring Docker images are ready..."
cd /etc/gustopos
sudo docker-compose pull --quiet 2>/dev/null || echo "✓ Using pre-cached images"
echo "✓ Docker images ready"

echo ""
echo "=========================================="
echo "Setup Complete!"
echo "=========================================="
echo ""
echo "Next steps:"
echo "1. Run: gustopos-start"
echo "2. Access the app at: https://192.168.56.X"
echo ""
echo "Find your VM IP address:"
echo "  ip addr show eth1"
echo ""
