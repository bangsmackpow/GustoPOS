#!/bin/sh
# gustopos-init - First-time setup for GustoPOS VirtualBox appliance

set -e

echo "=========================================="
echo "GustoPOS Appliance - First-Time Setup"
echo "=========================================="
echo ""

# Generate SSL certificates if they don't exist
if [ ! -f /etc/gustopos/ssl/cert.pem ]; then
    echo "[1/4] Generating self-signed SSL certificates..."
    mkdir -p /etc/gustopos/ssl
    openssl req -x509 -newkey rsa:4096 \
        -keyout /etc/gustopos/ssl/key.pem \
        -out /etc/gustopos/ssl/cert.pem \
        -days 365 -nodes \
        -subj "/C=US/ST=State/L=City/O=GustoPOS/CN=gustopos.local" \
        2>/dev/null
    echo "✓ SSL certificates generated"
else
    echo "[1/4] SSL certificates already exist (skipping)"
fi

# Create .env file from template if it doesn't exist
if [ ! -f /etc/gustopos/.env ]; then
    echo "[2/4] Creating .env configuration file..."
    cp /etc/gustopos/.env.template /etc/gustopos/.env
    echo "✓ .env file created at /etc/gustopos/.env"
    echo "  IMPORTANT: Review and customize as needed before starting containers"
else
    echo "[2/4] .env file already exists (skipping)"
fi

# Start Docker daemon if not running
echo "[3/4] Starting Docker daemon..."
if ! rc-service docker status > /dev/null 2>&1; then
    rc-service docker start || echo "Docker may already be running"
fi
echo "✓ Docker service started"

# Pull Docker images
echo "[4/4] Pulling Docker images (this may take a few minutes)..."
cd /opt/gustopos
docker-compose -f /etc/gustopos/docker-compose.yml pull --quiet 2>/dev/null || echo "Some images may need to be built"
echo "✓ Docker images ready"

echo ""
echo "=========================================="
echo "Setup Complete!"
echo "=========================================="
echo ""
echo "Next steps:"
echo "1. Edit /etc/gustopos/.env if needed"
echo "2. Run: gustopos-start"
echo "3. Access the app at: https://192.168.56.X"
echo ""
echo "Find your VM IP address:"
echo "  ip addr show eth1"
echo ""
