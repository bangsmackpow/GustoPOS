#!/bin/sh
# gustopos-start - Start the GustoPOS container stack

cd /opt/gustopos
docker-compose -f /etc/gustopos/docker-compose.yml up -d

echo "GustoPOS starting..."
echo ""
echo "Access the application at:"
echo "  https://192.168.56.X (replace X with your VM's IP)"
echo ""
echo "Default login credentials are in your .env file"
echo ""
echo "View logs with: gustopos-logs"
