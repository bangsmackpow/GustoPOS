#!/bin/sh
# gustopos-restore - Restore GustoPOS SQLite data from backup

if [ -z "$1" ]; then
    echo "Usage: gustopos-restore <backup_timestamp>"
    echo ""
    echo "Available backups:"
    ls -1 /data/backups/gustopos_backup_*.meta 2>/dev/null | sed 's|.*/gustopos_backup_||; s|.meta||' || echo "No backups found"
    exit 1
fi

TIMESTAMP="$1"
BACKUP_DIR="/data/backups"
BACKUP_PATH="$BACKUP_DIR/gustopos_backup_$TIMESTAMP"
DB_PATH="/data/db/gusto.db"

if [ ! -f "$BACKUP_PATH.db" ]; then
    echo "ERROR: Backup file not found: $BACKUP_PATH.db"
    exit 1
fi

echo "=========================================="
echo "GustoPOS Restore from $TIMESTAMP"
echo "=========================================="
echo ""

# Show what we're about to restore
if [ -f "$BACKUP_PATH.meta" ]; then
    cat "$BACKUP_PATH.meta"
    echo ""
fi

printf "Continue with restore? (y/N) "
read reply
case "$reply" in
    [Yy]*) ;;
    *) echo "Restore cancelled."; exit 1 ;;
esac

echo ""
echo "[1/3] Stopping containers..."
docker-compose -f /etc/gustopos/docker-compose.yml down

echo "[2/3] Restoring SQLite database..."
mkdir -p /data/db
cp "$BACKUP_PATH.db" "$DB_PATH"
echo "✓ Database file restored to $DB_PATH"

echo "[3/3] Restoring logs (if available)..."
if [ -f "$BACKUP_PATH-logs.tar.gz" ]; then
    # We use -C /data because the archive contains a 'logs/' directory
    tar -xzf "$BACKUP_PATH-logs.tar.gz" -C /data
    echo "✓ Logs restored"
else
    echo "✓ No logs to restore"
fi

echo "Starting containers..."
docker-compose -f /etc/gustopos/docker-compose.yml up -d

echo ""
echo "=========================================="
echo "Restore Complete!"
echo "=========================================="
echo ""
echo "Containers are starting. Check logs with: gustopos-logs"
echo ""
