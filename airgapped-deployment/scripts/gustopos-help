#!/bin/sh
# gustopos-help - Show help and useful commands for GustoPOS SQLite Appliance

cat << 'EOF'
════════════════════════════════════════════════════════════════════════════════
                         GustoPOS VirtualBox Appliance
════════════════════════════════════════════════════════════════════════════════

QUICK START
───────────────────────────────────────────────────────────────────────────────
  gustopos-init      Run first-time setup (generates SSL, creates .env)
  gustopos-start     Start the GustoPOS container stack
  gustopos-stop      Stop containers (data is preserved)
  gustopos-logs      View real-time container logs


ACCESSING THE APPLICATION
───────────────────────────────────────────────────────────────────────────────
  1. Find your VM's IP address:
     ip addr show eth1
     
  2. In your browser, navigate to:
     https://192.168.56.X (replace X with your VM IP)
     
  3. Accept the self-signed SSL certificate warning (normal)
  
  4. Login with credentials from /etc/gustopos/.env


CONFIGURATION
───────────────────────────────────────────────────────────────────────────────
  Edit settings:
    vi /etc/gustopos/.env
    
  Restart containers after editing:
    gustopos-stop && gustopos-start


BACKUPS
───────────────────────────────────────────────────────────────────────────────
  Create a backup:
    gustopos-backup
    
  List backups:
    ls -1 /data/backups/gustopos_backup_*.meta | head -5
    
  Restore from backup:
    gustopos-restore <timestamp>


TROUBLESHOOTING
───────────────────────────────────────────────────────────────────────────────
  View container status:
    docker-compose -f /etc/gustopos/docker-compose.yml ps
    
  View errors in logs:
    gustopos-logs | grep error
    
  Check Docker daemon:
    rc-service docker status
    
  Check disk space:
    df -h


ADVANCED MANAGEMENT (SQLite)
───────────────────────────────────────────────────────────────────────────────
  Connect directly to SQLite (inside API container):
    docker exec -it gustopos-api sqlite3 /app/data/gusto.db
    
  Copy database file to current directory:
    cp /data/db/gusto.db ./gusto_copy.db
    
  View container details:
    docker ps -a
    docker inspect gustopos-api
    docker stats


USEFUL PATHS
───────────────────────────────────────────────────────────────────────────────
  Configuration:     /etc/gustopos/
  Data (Container):  /data/
  Database file:     /data/db/gusto.db
  Logs:              /data/logs/
  Backups:           /data/backups/
  SSL Certificates:  /etc/gustopos/ssl/


FOR MORE HELP
───────────────────────────────────────────────────────────────────────────────
  View this help anytime:
    gustopos-help


════════════════════════════════════════════════════════════════════════════════
EOF
