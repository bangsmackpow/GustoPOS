#!/bin/sh
# gustopos-backup - Backup GustoPOS SQLite data

BACKUP_DIR="/data/backups"
DB_PATH="/data/db/gusto.db"
TIMESTAMP=$(date +%Y%m%d_%H%M%S)
BACKUP_PATH="$BACKUP_DIR/gustopos_backup_$TIMESTAMP"

mkdir -p "$BACKUP_DIR"

echo "Starting GustoPOS backup ($TIMESTAMP)..."
echo ""

# Backup database
echo "[1/3] Backing up SQLite database..."
if [ -f "$DB_PATH" ]; then
    cp "$DB_PATH" "$BACKUP_PATH.db"
    echo "✓ Database backed up to: $BACKUP_PATH.db"
else
    echo "⚠ Database not found at $DB_PATH - check if app has started"
fi

# Backup logs
echo "[2/3] Backing up logs..."
tar -czf "$BACKUP_PATH-logs.tar.gz" -C /data logs/ 2>/dev/null || echo "✓ No logs to backup (first run)"
echo "✓ Logs backed up"

# Create metadata file
echo "[3/3] Creating backup metadata..."
cat > "$BACKUP_PATH.meta" << EOF
Backup Timestamp: $TIMESTAMP
Hostname: $(hostname)
System Time: $(date)
GustoPOS Version: v1.0
Database: SQLite (LibSQL)

Files:
  - $BACKUP_PATH.db (database file)
  - $BACKUP_PATH-logs.tar.gz (logs archive)

Restore with: gustopos-restore $TIMESTAMP
EOF

echo "✓ Backup metadata saved"
echo ""
echo "=========================================="
echo "Backup Complete!"
echo "=========================================="
echo ""
echo "Backed up to: $BACKUP_DIR/gustopos_backup_$TIMESTAMP"
echo ""
echo "To restore: gustopos-restore $TIMESTAMP"
echo ""
