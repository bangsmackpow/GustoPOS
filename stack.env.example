# GustoPOS Environment Configuration Template
# Copy this file to stack.env and update the values

# --- API Server Configuration ---
PORT=3000
# Path to the SQLite database file inside the container
# This must match the volume mapping in docker-compose.yml
DATABASE_URL=file:/app/data/gusto.db

# --- Admin Login Credentials ---
# These are used for the main dashboard login
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-immediately
# The PIN used for staff switching on the POS interface (4 digits)
ADMIN_PIN=0000
ADMIN_LOGIN_ENABLED=true

# --- Initial Setup ---
# Set to true to allow the /api/admin/seed endpoint to run
ADMIN_SEED_ENABLED=true

# --- Security (Optional) ---
# Set to true to enable 2FA via TOTP (e.g. Google Authenticator)
ADMIN_2FA_ENABLED=false
# If 2FA is enabled, generate a secure random secret
ADMIN_TOTP_SECRET=JBSWY3DPEHPK3PXP

# --- Development (Optional) ---
# Enable dummy login for testing (bypass admin check)
DEV_LOGIN=false
DEV_ADMIN_EMAIL=dev@example.com
DEV_ADMIN_PASSWORD=dev-secret
