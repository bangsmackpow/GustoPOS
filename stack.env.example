# GustoPOS Environment Configuration Template
# Copy this file to stack.env and update the values

# --- API Server Configuration ---
PORT=3000
# Path to the SQLite database file inside the container
DATABASE_URL=file:/app/data/gusto.db

# --- Litestream Backup Configuration (Optional) ---
# Used for real-time replication to Cloudflare R2 or S3
# Example URL: s3://gustopos-backups/gusto.db
LITESTREAM_REPLICA_URL=
# Example Endpoint: https://<accountid>.r2.cloudflarestorage.com
LITESTREAM_ENDPOINT=
LITESTREAM_ACCESS_KEY_ID=
LITESTREAM_SECRET_ACCESS_KEY=

# --- Admin Login Credentials ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-immediately
ADMIN_PIN=0000
ADMIN_LOGIN_ENABLED=true

# --- Initial Setup ---
ADMIN_SEED_ENABLED=true
